# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copiez ce fichier en ".env" et remplissez vos vraies valeurs.
# Le fichier ".env" est IGNORÉ par Git (voir .gitignore).
# Seul ".env.example" doit être commité — il ne contient aucun secret.
# ─────────────────────────────────────────────────────────────────────────────

# Airtable Personal Access Token
# Créez-le sur : https://airtable.com/create/tokens
# Portée requise : data.records:write  sur votre base
AIRTABLE_TOKEN=patXXXXXXXXXXXXXXXX

# Identifiant de votre base Airtable
# Visible dans l'URL de votre base : airtable.com/appXXXX/...
AIRTABLE_BASE=appXXXXXXXXXXXXXX

# Nom exact de la table dans votre base (sensible à la casse)
AIRTABLE_TABLE=Participants
